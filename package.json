{
  "name": "loom-ide",
  "version": "0.2.0",
  "description": "织网 IDE — 国产 AI 原生开发环境，内嵌 Orca 智能体",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build && electron-builder --win",
    "start": "electron ."
  },
  "dependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.61.1",
    "@vscode/codicons": "^0.0.45",
    "asynckit": "^0.5.0",
    "bluebird": "^3.7.2",
    "buffer-crc32": "^1.0.0",
    "chromium-pickle-js": "^0.2.0",
    "combined-stream": "^1.0.8",
    "commander": "^15.0.0",
    "delayed-stream": "^1.0.0",
    "es6-error": "^4.1.1",
    "fd-slicer": "^1.1.0",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.5",
    "fs.realpath": "^1.0.0",
    "function-bind": "^1.1.2",
    "inflight": "^1.0.6",
    "inherits": "^2.0.4",
    "json-stringify-safe": "^5.0.1",
    "jsonfile": "^6.2.1",
    "monaco-editor": "^0.52.0",
    "ms": "^2.1.3",
    "node-int64": "^0.4.0",
    "node-pty": "^1.1.0",
    "object-keys": "^1.1.1",
    "once": "^1.4.0",
    "pend": "^1.2.0",
    "progress": "^2.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "require-directory": "^2.1.1",
    "retry": "^0.13.1",
    "safer-buffer": "^2.1.2",
    "semver-compare": "^1.0.0",
    "source-map": "^0.7.6",
    "stat-mode": "^1.0.0",
    "sumchecker": "^3.0.1",
    "temp": "^0.9.4",
    "truncate-utf8-bytes": "^1.0.2",
    "util-deprecate": "^1.0.2",
    "wcwidth": "^1.0.1",
    "wrappy": "^1.0.2",
    "xmlbuilder": "^15.1.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "yauzl": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "has-flag": "^5.0.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "build": {
    "appId": "com.loom.ide",
    "productName": "Loom IDE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "resources/**/*"
    ],
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Loom IDE"
    }
  }
}
