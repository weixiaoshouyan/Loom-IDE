{
  "name": "loom-ide",
  "version": "0.1.0",
  "description": "织网 IDE — 国产 AI 原生开发环境，内嵌 Orca 智能体",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.main.json && vite build && electron-builder --win",
    "start": "electron ."
  },
  "dependencies": {
    "monaco-editor": "^0.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.loom.ide",
    "productName": "Loom IDE",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "public/**/*"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }] }
  }
}
